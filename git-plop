#!/usr/bin/env python3

USAGE = """git-plop

git-plop enables updating multiple remote branches from unmerged commits on a single local branch.

git-plop works primarily using a pseudo "change id", akin to a Gerrit or Jujutsu change id,
calculated as a hash of the author's name, email, time, and timezone. Author information within a
commit rarely changes across rebases or cherry-picks, and authors rarely commit more than once a
second. Note that git-plop will behave strangely if a particular author commits more than once a
second.

git-plop keeps a small database in .git/info/plop/ which includes mappings of change ids to target
branches.

git-plop aim
git-plop aim --all [remote [ref]]
git-plop aim [ref [ref [ref ...]]]
git-plop aim [ref] -t target-branch

    This command sets the target branch of a particular ref in the plop database.

    If no arguments are provided, it generates a target branch name and sets it for HEAD if HEAD
    does not already have one.
    If --all is provided, then all unmerged commits are aimed with a synthetic branch if they don't
    already have one. See git-plop unmerged.
    If one or more arguments are provided without -t, each argument is set to a new synthetic
    target branch if one does not exist.
    If -t is provided, then the given ref (or HEAD, if none is given) is set to the given branch.

    If target-branch is not specified, it is generated with the following format:

        <namespace>/<trimmed-message>-<shortcode>

    <namespace> is determined by either looking in git config for 'plop.branch-namespace' or using
    the current system username.
    <trimmed-message> is determined by taking the first 12 alphanumeric characters of the commit
    message. Non-alphanumeric characters are replaced with dashes.
    <shortcode> is 6 random base 32 digits from /dev/urandom.

git-plop disarm
git-plop disarm [ref [ref [ref ...]]]

    This command undoes git-plop aim for the given refs, defaulting to HEAD if none are given.

git-plop id [ref]

    This command shows the git-plop change id for the ref, defaulting to HEAD.

git-plop lookup [ref]

    This command shows the git-plop destination branch for the ref, defaulting to HEAD.

git-plop unmerged [remote [ref]]

    This command shows all commits that are currently unmerged to the remote branch. It does this
    by looking at the ref, finding the merge-base of ref and the current remote tracking
    branch (or the default branch on the remote if no tracking branch is found), and then looking
    at that chain.
    The commit chain from merge-base to ref must be a unique linear path. If multiple paths
    exist, an error is raised.

    If remote is not specified, it defaults to the default remote that git push would use.
    If ref is not specified, it defaults to HEAD.

git-plop lob [remote [ref]]

    For each commit in the unmerged set, this command considers whether it has been aimed. If not,
    it adds it to a refspec to push to the remote with --atomic and --force-with-lease.
    This will update the specified remote branch for every commit that is found to have a
    destination. No other refs besides aimed refs are pushed.

git-plop log [remote [ref]]

    This command shows the current unmerged commits along with their change ids and destination
    branches.

git-plop branch [-r] [remote [ref]]

    For better usability with other tools, this tool will make or update local git-plop branches in
    a 'plop/' branch namespace for every aimed git commit in the local database. If [-r] is set,
    target branch annotations are removed.

git-plop clean

    Removes all git-plop data.
"""

import base64
import hashlib
import os
import subprocess
import sys

BRANCH_NAME_LEN = 12
SHORTCODE_LEN = 6


def trim_message(message):
    subject = message.split("\n", 1)[0]
    subject = "".join([ch.lower() if ch.isalnum() else "-" for ch in subject])
    return subject[:BRANCH_NAME_LEN].rstrip("-")


def generate_shortcode():
    raw = os.urandom(SHORTCODE_LEN)
    return base64.b32encode(raw).decode("utf-8").lower().rstrip("=")[:SHORTCODE_LEN]


class Repo:
    def __init__(self, work_dir=None):
        self.work_dir = work_dir
        self.db_dir = os.path.join(
            self.run(["rev-parse", "--absolute-git-dir"]).stdout.strip(),
            "info", "plop", "dbc")
        os.makedirs(self.db_dir, exist_ok=True)

    def run(self, args, check_returncode=True, capture_output=True, **kwargs):
        cmd = ["git"] + args
        if args[0] in ("push", "hash-object", "update-ref", "mktree"):
            print(cmd, file=sys.stderr)
        result = subprocess.run(cmd, cwd=self.work_dir, text=True, capture_output=capture_output,
                                **kwargs)
        if check_returncode:
            result.check_returncode()
        return result

    def validate(self):
        self.run(["rev-parse", "--git-dir"])
        self.run(["rev-parse", "HEAD"])

    def read_commit(self, ref):
        header, _, body = self.run(["cat-file", "-p", ref]).stdout.partition("\n\n")
        return header, body

    def change_id(self, ref=None):
        if ref is None: ref = "HEAD"
        header, _ = self.read_commit(ref)
        author = [l for l in header.splitlines() if l.startswith("author ")]
        if len(author) != 1:
            raise SystemExit("error: author information not found in commit %r" % ref)
        h = hashlib.sha256(("plop-id " + author[0]).encode("utf-8"))
        return base64.b32encode(h.digest())[:20].decode("utf-8").lower()

    def get_namespace(self):
        ns = self.run(["config", "--default", "", "plop.branch-namespace"]).stdout.strip()
        if ns: return ns
        try:
            return subprocess.check_output(["whoami"], text=True).strip()
        except subprocess.CalledProcessError:
            raise SystemExit("error: plop.branch-namespace not set and whoami failed")

    def generate_branch_name(self):
        _, body = self.read_commit("HEAD")
        trimmed = trim_message(body)
        if trimmed:
            trimmed += "-"
        shortcode = generate_shortcode()
        return f"{self.get_namespace()}/{trimmed}{shortcode}"

    def get_default_remote(self):
        try:
            branch = self.run(["symbolic-ref", "--short", "HEAD"]).stdout.strip()
        except subprocess.CalledProcessError:
            branch = None
        else:
            try:
                return self.run(["config", f"branch.{branch}.pushRemote"]).stdout.strip()
            except subprocess.CalledProcessError:
                pass

        try:
            return self.run(["config", "remote.pushDefault"]).stdout.strip()
        except subprocess.CalledProcessError:
            pass

        if branch:
            try:
                return self.run(["config", f"branch.{branch}.remote"]).stdout.strip()
            except subprocess.CalledProcessError:
                pass

        raise SystemExit("error: could not determine remote; specify one explicitly")

    def get_merge_base_ref(self, remote):
        try:
            branch = self.run(["symbolic-ref", "--short", "HEAD"]).stdout.strip()
            merge = self.run(["config", f"branch.{branch}.merge"]).stdout.strip()
            branch_remote = self.run(["config", f"branch.{branch}.remote"]).stdout.strip()
            if branch_remote == remote:
                short = merge.removeprefix("refs/heads/")
                return f"refs/remotes/{remote}/{short}"
        except subprocess.CalledProcessError:
            pass

        try:
            return self.run(["symbolic-ref", f"refs/remotes/{remote}/HEAD"]).stdout.strip()
        except subprocess.CalledProcessError:
            pass

        raise SystemExit("error: could not determine merge base from here")

    def find_unique_path(self, start, end):
        start_hash = self.run(["rev-parse", start]).stdout.strip()
        end_hash = self.run(["rev-parse", end]).stdout.strip()
        if start_hash == end_hash: return []

        try:
            output = self.run(
                ["rev-list", "--ancestry-path", "--parents",
                 f"{start_hash}..{end_hash}"]
            ).stdout
        except subprocess.CalledProcessError:
            raise SystemExit(
                f"error: no path found from {start_hash[:12]} to {end_hash[:12]}")

        ancestors = {}
        for line in output.splitlines():
            if not line.strip():
                continue
            parts = line.split()
            commit = parts[0]
            parents = parts[1:]
            if len(parents) > 1:
                raise SystemExit("merge commit rejected")
            ancestors[commit] = parents[0]

        # An empty result (rev-list exits 0 with no output) means end is not a
        # descendant of start at all.
        if not ancestors:
            raise SystemExit(
                f"error: no path found from {start_hash[:12]} to {end_hash[:12]}")

        node = end_hash
        path = []
        while node != start_hash:
            if node not in ancestors:
                raise SystemExit(
                    f"error: no unique linear path from {start_hash[:12]} to "
                    f"{end_hash[:12]} (chain broken at {node[:12]})")
            path.append(node)
            node = ancestors[node]

        return list(reversed(path))

    def lookup_by_change(self, change_id):
        p = os.path.join(self.db_dir, change_id)
        if not os.path.exists(p): return ""
        with open(p, encoding="utf-8") as fh:
            return fh.read().strip()

    def lookup(self, ref=None):
        if ref is None: ref = "HEAD"
        return self.lookup_by_change(self.change_id(ref))

    def validate_branch_name(self, target):
        if target == "_":
            raise SystemExit("invalid target branch %r" % target)
        self.run(["check-ref-format", f"refs/heads/{target}"])

    def aim(self, ref=None, target=None):
        if ref is None: ref = "HEAD"
        change_id = self.change_id(ref)
        if target is None:
            if self.lookup_by_change(change_id): return
            target = self.generate_branch_name()
        self.validate_branch_name(target)
        p = os.path.join(self.db_dir, change_id)
        with open(p, "w", encoding="utf-8") as fh:
            fh.write(target)
        print("%s -> %s" % (change_id, target))

    def disarm(self, ref=None):
        if ref is None: ref = "HEAD"
        change_id = self.change_id(ref)
        p = os.path.join(self.db_dir, change_id)
        if not os.path.exists(p): return
        os.remove(p)
        print("%s -> _" % change_id)

    def unmerged(self, remote=None, ref=None):
        if ref is None:
            ref = "HEAD"
        if remote is None:
            remote = self.get_default_remote()

        base_ref = self.get_merge_base_ref(remote)
        merge_base = self.run(["merge-base", base_ref, ref]).stdout.strip()

        commits = self.find_unique_path(merge_base, ref)
        return (remote, ref, commits)

    def lob(self, remote=None, ref=None):
        remote, ref, commits = self.unmerged(remote=remote, ref=ref)

        if not commits:
            print("No commits found.", file=sys.stderr)
            return

        refspecs = []
        for commit in commits:
            dest = self.lookup(commit)
            if dest:
                refspecs.append(f"{commit}:refs/heads/{dest}")

        if not refspecs:
            print("No aimed commits found.", file=sys.stderr)
            return

        self.run(["push", "--atomic", "--force-with-lease", remote] + refspecs,
                 capture_output=False)

    def update_branches(self, remote=None, ref=None, remove=False):
        local_branches = self.run([
            "for-each-ref", "--format=%(refname)", "refs/heads/plop/"]).stdout.splitlines()
        for branch in local_branches:
            if not branch.startswith("refs/heads/plop/"): continue
            if remove or branch != "refs/heads/plop/" + self.lookup(branch):
                self.run(["update-ref", "-d", branch])
        if remove: return
        _, _, commits = self.unmerged(remote=remote, ref=ref)
        for commit in commits:
            target = self.lookup(commit)
            if target:
                self.run(["update-ref", "refs/heads/plop/" + target, commit])


def usage(c=1):
    print(USAGE)
    sys.exit(c)


def main():
    args = sys.argv[1:]

    if not args or "-h" in args or "--help" in args:
        usage(0)

    repo = Repo()
    repo.validate()

    cmd, args = args[0], args[1:]

    def remote_ref(args):
        if len(args) == 0:
            return None, None
        if len(args) == 1:
            return args[0], None
        if len(args) == 2:
            return args[0], args[1]
        usage()

    if cmd == "aim":
        if "--all" in args:
            if args[0] != "--all": usage()
            _, _, refs = repo.unmerged(*remote_ref(args[1:]))
            for ref in refs:
                repo.aim(ref=ref)
            return
        if "-t" in args:
            if len(args) == 2:
                if args[0] != "-t": usage()
                return repo.aim(target=args[1])
            if len(args) == 3:
                if args[1] != "-t": usage()
                return repo.aim(ref=args[0], target=args[2])
            usage()
        if len(args) == 0: return repo.aim()
        for ref in args:
            repo.aim(ref=ref)
        return

    if cmd == "disarm":
        if len(args) == 0: return repo.disarm()
        for ref in args:
            repo.disarm(ref=ref)
        return

    if cmd == "id":
        if len(args) > 1: usage()
        print(repo.change_id(ref=(args[0] if len(args) == 1 else None)))
        return

    if cmd == "lookup":
        if len(args) > 1: usage()
        target = repo.lookup(ref=(args[0] if len(args) == 1 else None))
        if target: print(target)
        return

    if cmd == "unmerged":
        _, _, refs = repo.unmerged(*remote_ref(args))
        for ref in refs:
            print(ref)
        return

    if cmd == "lob":
        return repo.lob(*remote_ref(args))

    if cmd == "log":
        _, _, refs = repo.unmerged(*remote_ref(args))
        for ref in refs:
            change_id = repo.change_id(ref)
            target = repo.lookup_by_change(change_id)
            print("%s\t%s\t%s" % (ref, change_id, target or "_"))
        return

    if cmd == "branch":
        remove = False
        if "-r" in args:
            remove = True
            if args[0] == "-r":
                args = args[1:]
            elif args[-1] == "-r":
                args = args[:-1]
            else:
                usage()
        remote, ref = remote_ref(args)
        return repo.update_branches(remote=remote, ref=ref, remove=remove)

    if cmd == "clean":
        if len(args) > 0: usage()
        repo.update_branches(remove=True)
        shutil.rmtree(os.repo.db_dir)

    print(f"Unknown command: {cmd}", file=sys.stderr)
    usage()


if __name__ == "__main__":
    main()
