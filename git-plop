#!/usr/bin/env python3

USAGE = """git-plop

git-plop enables updating multiple remote branches from unmerged commits on a single local branch.

git-plop works primarily using a pseudo "change id", akin to a Gerrit or Jujutsu change id,
calculated as a hash of the author's name, email, time, and timezone. Author information within a
commit rarely changes across rebases or cherry-picks, and authors rarely commit more than once a
second. Note that git-plop will behave strangely if a particular author commits more than once a
second.

git-plop keeps a small database in .git/info/plop/ which includes mappings of change ids to target
branches.

git-plop aim [ref] [remote-branch]

    This command sets the target branch of a particular ref in the plop database.

    If no arguments are provided, it generates a remote branch name and sets it for HEAD.
    If one argument is provided, it is evaluated to see if it already references anything.
        If the one argument does reference something, it is assumed to be 'ref', and a remote
        branch is synthesized and set.
        If the argument does not reference something in the repo already, then the argument is
        assumed to be 'remote-branch' and HEAD is set to it.
    If two arguments are provided, the command is fully specified.

    If remote-branch is not specified, it is generated with the following format:

        <namespace>/<trimmed-message>-<shortcode>

    <namespace> is determined by either looking in git config for 'plop.branch-namespace' or using
    the current system username.
    <trimmed-message> is determined by taking the first 12 alphanumeric characters of the commit
    message. Non-alphanumeric characters are replaced with dashes.
    <shortcode> is 6 random base 32 digits from /dev/urandom.

git-plop disarm [ref]

    This command undoes git-plop aim for ref, defaulting to HEAD.

git-plop lob [remote [ref]]

    This command looks at the ref, finds the merge-base of ref and the current remote tracking
    branch (or the default branch on the remote if no tracking branch is found), and then, for each
    commit in that chain, considers whether it has been aimed.

    A single refspec is generated that is pushed to the remote with --atomic and --force-with-lease
    that updates the specified remote branch for every commit that is found to have the trailer.
    No other refs besides aimed refs are pushed.

    The commit chain from merge-base to ref must be a unique linear path. If multiple paths
    exist, an error is raised.

    If remote is not specified, it defaults to the default remote that git push would use.
    If ref is not specified, it defaults to HEAD.

git-plop id [ref]

    This command shows the git-plop change id for the ref.

git-plop lookup [ref]

    This command shows the git-plop destination branch for the ref.

git-plop show [remote [ref]]

    This command simply shows what target branch each ref might get pushed to.

git-plop branch [-r] [remote [ref]]

    For better usability with other tools, this tool will make or update local git-plop branches in
    a 'plop/' branch namespace for every aimed git commit in the local database. If [-r] is set,
    target branch annotations are removed.

git-plop align [remote]

    This command aligns submodule pointers across commits between the merge-base and HEAD.

    For each submodule, it finds the submodule's ref at the merge-base (the base ref) and
    the submodule's current HEAD. It then walks commits on both the outer repo and the
    submodule, matching them by shared aimed branch names.

    For each commit in the outer repo, the submodule pointer is set to match the parent
    commit's pointer, unless the commit has a destination branch that is shared with the
    submodule, in which case the pointer advances to the submodule commit with that
    destination branch.

    Shared destination branches must appear in the same order in both the outer repo and
    the submodule. If they don't, an error is raised.

    If remote is not specified, it defaults to the default remote that git push would use.
"""

import base64
import hashlib
import hmac
import os
import re
import subprocess
import sys

BRANCH_NAME_LEN = 12
SHORTCODE_LEN = 6


def trim_message(message):
    subject = message.split("\n", 1)[0]
    subject = "".join([ch.lower() if ch.isalnum() else "-" for ch in subject])
    return subject[:BRANCH_NAME_LEN].rstrip("-")


def generate_shortcode():
    with open("/dev/urandom", "rb") as f:
        raw = f.read(SHORTCODE_LEN)
    return base64.b32encode(raw).decode("utf-8").lower().rstrip("=")[:SHORTCODE_LEN]


class Repo:
    def __init__(self, git_dir=None, work_dir=None):
        self.git_dir = git_dir
        self.work_dir = work_dir

    def _git_cmd(self, base_cmd):
        result = [base_cmd[0]]
        if self.work_dir is not None:
            result += ["-C", self.work_dir]
        if self.git_dir is not None:
            result += ["--git-dir", self.git_dir]
        result += base_cmd[1:]
        return result

    def run(self, args, check_returncode=True, capture_output=True, **kwargs):
        cmd = self._git_cmd(["git"] + args)
        if args[0] in ("push", "hash-object", "update-ref", "mktree"):
            print(cmd, file=sys.stderr)
        result = subprocess.run(cmd, text=True, capture_output=capture_output, **kwargs)
        if check_returncode:
            result.check_returncode()
        return result

    def read_commit(self, ref):
        header, _, body = self.run(["cat-file", "-p", ref]).stdout.partition("\n\n")
        return header, body

    def write_commit_object(self, header, body):
        full = header + "\n\n" + body
        if full and not full.endswith("\n"):
            full += "\n"
        return self.run(
            ["hash-object", "-t", "commit", "-w", "--stdin"],
            input=full,
        ).stdout.strip()

    def update_head(self, new_commit):
        try:
            symref = self.run(["symbolic-ref", "-q", "HEAD"])
        except:
            self.run(["update-ref", "HEAD", new_commit])
        else:
            self.run(["update-ref", symref.stdout.strip(), new_commit])

    def validate(self):
        self.run(["rev-parse", "--git-dir"])
        self.run(["rev-parse", "HEAD"])

    def change_id(self, ref=None):
        if ref is None: ref = "HEAD"
        header, _ = self.read_commit(ref)
        author = [l for l in header.splitlines() if l.startswith("author ")]
        if len(author) != 1:
            raise SystemExit("error: author information not found in commit %r" % ref)
        h = hmac.new("plop-id".encode("utf-8"), author[0].encode("utf-8"), hashlib.sha256)
        return base64.b32encode(h.digest())[:20].decode("utf-8").lower()

    def db_dir(self):
        p = os.path.join(self.run(["rev-parse", "--absolute-git-dir"]).stdout.strip(),
                         "info", "plop", "dbt")
        os.makedirs(p, exist_ok=True)
        return p

    def has_ref(self, ref):
        result = self.run(["rev-parse", "--verify", ref], check_returncode=False)
        return result.returncode == 0

    def _get_namespace(self):
        ns = self.run(["config", "--default", "", "plop.branch-namespace"]).stdout.strip()
        if ns: return ns
        try:
            return subprocess.check_output(["whoami"], text=True).strip()
        except subprocess.CalledProcessError:
            raise SystemExit("error: plop.branch-namespace not set and whoami failed")

    def generate_branch_name(self):
        _, body = self.read_commit("HEAD")
        trimmed = trim_message(body)
        if trimmed:
            trimmed += "-"
        shortcode = generate_shortcode()
        return f"{self._get_namespace()}/{trimmed}{shortcode}"

    def get_default_remote(self):
        try:
            branch = self.run(["symbolic-ref", "--short", "HEAD"]).stdout.strip()
        except subprocess.CalledProcessError:
            branch = None
        else:
            try:
                return self.run(["config", f"branch.{branch}.pushRemote"]).stdout.strip()
            except subprocess.CalledProcessError:
                pass

        try:
            return self.run(["config", "remote.pushDefault"]).stdout.strip()
        except subprocess.CalledProcessError:
            pass

        if branch:
            try:
                return self.run(["config", f"branch.{branch}.remote"]).stdout.strip()
            except subprocess.CalledProcessError:
                pass

        raise SystemExit("error: could not determine remote; specify one explicitly")

    def get_merge_base_ref(self, remote):
        try:
            branch = self.run(["symbolic-ref", "--short", "HEAD"]).stdout.strip()
            merge = self.run(["config", f"branch.{branch}.merge"]).stdout.strip()
            branch_remote = self.run(["config", f"branch.{branch}.remote"]).stdout.strip()
            if branch_remote == remote:
                short = merge.removeprefix("refs/heads/")
                return f"refs/remotes/{remote}/{short}"
        except subprocess.CalledProcessError:
            pass

        try:
            return self.run(["symbolic-ref", f"refs/remotes/{remote}/HEAD"]).stdout.strip()
        except subprocess.CalledProcessError:
            pass

        raise SystemExit("error: could not determine merge base from here")

    def find_unique_path(self, start, end):
        start_hash = self.run(["rev-parse", start]).stdout.strip()
        end_hash = self.run(["rev-parse", end]).stdout.strip()
        if start_hash == end_hash: return []

        try:
            output = self.run(
                ["rev-list", "--ancestry-path", "--parents",
                 f"{start_hash}..{end_hash}"]
            ).stdout
        except subprocess.CalledProcessError:
            raise SystemExit(
                f"error: no path found from {start_hash[:12]} to {end_hash[:12]}")

        ancestors = {}
        for line in output.splitlines():
            if not line.strip():
                continue
            parts = line.split()
            commit = parts[0]
            parents = parts[1:]
            if len(parents) > 1:
                raise SystemExit("merge commit rejected")
            ancestors[commit] = parents[0]

        node = end_hash
        path = []
        while node != start_hash:
            path.append(node)
            node = ancestors[node]

        return list(reversed(path))

    def get_toplevel(self):
        return self.run(["rev-parse", "--show-toplevel"]).stdout.strip()

    def read_tree(self, tree_hash):
        output = self.run(["ls-tree", tree_hash]).stdout
        entries = []
        for line in output.splitlines():
            if not line:
                continue
            meta, name = line.split("\t", 1)
            parts = meta.split()
            entries.append((parts[0], parts[1], parts[2], name))
        return entries

    def write_tree(self, entries):
        input_data = "".join(
            f"{mode} {type_} {hash_}\t{name}\n"
            for mode, type_, hash_, name in entries
        )
        return self.run(["mktree"], input=input_data).stdout.strip()

    def update_tree_entry(self, tree_hash, path, new_hash):
        parts = path.split("/", 1)
        name = parts[0]

        entries = self.read_tree(tree_hash)

        if len(parts) == 1:
            new_entries = []
            found = False
            for mode, type_, hash_, entry_name in entries:
                if entry_name == name:
                    new_entries.append((mode, type_, new_hash, entry_name))
                    found = True
                else:
                    new_entries.append((mode, type_, hash_, entry_name))
            if not found:
                raise SystemExit(
                    f"error: entry '{name}' not found in tree {tree_hash[:12]}")
            return self.write_tree(new_entries)

        rest = parts[1]
        new_entries = []
        found = False
        for mode, type_, hash_, entry_name in entries:
            if entry_name == name:
                new_subtree = self.update_tree_entry(hash_, rest, new_hash)
                new_entries.append((mode, type_, new_subtree, entry_name))
                found = True
            else:
                new_entries.append((mode, type_, hash_, entry_name))
        if not found:
            raise SystemExit(
                f"error: directory '{name}' not found in tree "
                f"{tree_hash[:12]}")
        return self.write_tree(new_entries)

    def get_submodules(self, ref="HEAD"):
        output = self.run(["ls-tree", "-r", ref]).stdout
        submodules = []
        for line in output.splitlines():
            if not line:
                continue
            meta, name = line.split("\t", 1)
            mode = meta.split()[0]
            if mode == "160000":
                submodules.append(name)
        return submodules

    def get_submodule_ref(self, commit, submodule_path):
        try:
            output = self.run(["ls-tree", commit, "--", submodule_path]).stdout
        except subprocess.CalledProcessError:
            return None
        if not output.strip():
            return None
        meta, _ = output.strip().split("\t", 1)
        return meta.split()[2]

    def aim(self, ref=None, target=None):
        if ref is None: ref = "HEAD"
        if target is None: target = self.generate_branch_name()
        change_id = self.change_id(ref)
        p = os.path.join(self.db_dir(), change_id)
        with open(p, "w", encoding="utf-8") as fh:
            fh.write(target)
        print("%s -> %s" % (change_id, target))

    def lookup(self, ref=None):
        if ref is None: ref = "HEAD"
        change_id = self.change_id(ref)
        p = os.path.join(self.db_dir(), change_id)
        if not os.path.exists(p): return ""
        with open(p, encoding="utf-8") as fh:
            return fh.read()

    def disarm(self, ref=None):
        if ref is None: ref = "HEAD"
        change_id = self.change_id(ref)
        p = os.path.join(self.db_dir(), change_id)
        if not os.path.exists(p): return
        os.remove(p)
        print("%s -> _" % ref)

    def get_commits(self, remote=None, ref=None):
        if ref is None:
            ref = "HEAD"
        if remote is None:
            remote = self.get_default_remote()

        base_ref = self.get_merge_base_ref(remote)
        merge_base = self.run(["merge-base", base_ref, ref]).stdout.strip()

        commits = self.find_unique_path(merge_base, ref)
        return (remote, ref, commits)

    def lob(self, remote=None, ref=None):
        remote, ref, commits = self.get_commits(remote=remote, ref=ref)

        if not commits:
            print("No commits found.", file=sys.stderr)
            return

        refspecs = []
        for commit in commits:
            dest = self.lookup(commit)
            if dest:
                refspecs.append(f"{commit}:refs/heads/{dest}")

        if not refspecs:
            print("No aimed commits found.", file=sys.stderr)
            return

        self.run(["push", "--atomic", "--force-with-lease", remote] + refspecs,
                 capture_output=False)

    def update_branches(self, remote=None, ref=None, remove=False):
        local_branches = self.run([
            "for-each-ref", "--format=%(refname)", "refs/heads/plop/"]).stdout.splitlines()
        for branch in local_branches:
            if not branch.startswith("refs/heads/plop/"): continue
            if remove or branch != "refs/heads/plop/" + self.lookup(branch):
                self.run(["update-ref", "-d", branch])
        if remove: return
        remote, ref, commits = self.get_commits(remote=remote, ref=ref)
        for ref in commits:
            target = self.lookup(ref)
            if target:
                self.run(["update-ref", "refs/heads/plop/" + target, ref])

    def align(self, remote=None):
        if remote is None:
            remote = self.get_default_remote()

        # Find merge base of outer repo
        base_ref = self.get_merge_base_ref(remote)
        merge_base = self.run(["merge-base", base_ref, "HEAD"]).stdout.strip()

        # Get unique path from merge-base to HEAD
        a_commits = self.find_unique_path(merge_base, "HEAD")
        if not a_commits:
            print("No commits to align.", file=sys.stderr)
            return

        # Collect dest branches from A commits (in order)
        a_branches = []
        for commit in a_commits:
            dest = self.db.get_dest_branch(self, commit)
            if dest:
                a_branches.append((commit, dest))

        # Find submodules at HEAD
        submodules = self.get_submodules("HEAD")
        if not submodules:
            print("No submodules found.", file=sys.stderr)
            return

        toplevel = self.get_toplevel()

        # For each submodule, compute target B ref for each A commit
        submodule_targets = {}

        for sub_path in submodules:
            # B0: what A's merge-base says the submodule should be
            b0 = self.get_submodule_ref(merge_base, sub_path)
            if b0 is None:
                continue

            # B HEAD: the submodule's actual current commit
            sub_repo = Repo(self.db, work_dir=toplevel + "/" + sub_path)
            b_head = sub_repo.run(["rev-parse", "HEAD"]).stdout.strip()

            # B latest committed:
            b_remote = sub_repo.get_merge_base_ref(remote)

            if b0 == b_head:
                continue

            b_commits = sub_repo.find_unique_path(b_remote, b_head)
            if not b_commits:
                continue

            # Collect dest branches from B commits (in order)
            b_branches = []
            for commit in b_commits:
                dest = sub_repo.db.get_dest_branch(sub_repo, commit)
                if dest:
                    b_branches.append((commit, dest))

            # Find shared destination branches
            a_branch_set = {b for _, b in a_branches}
            b_branch_set = {b for _, b in b_branches}
            shared = a_branch_set & b_branch_set

            if not shared:
                continue

            # Verify shared branches appear in the same order
            a_shared_order = [b for _, b in a_branches if b in shared]
            b_shared_order = [b for _, b in b_branches if b in shared]
            if a_shared_order != b_shared_order:
                raise SystemExit(
                    f"error: shared destination branches for submodule "
                    f"'{sub_path}' appear in different order in outer repo "
                    f"and submodule")

            # Map shared dest branch -> B commit
            b_branch_to_commit = {}
            for commit, branch in b_branches:
                if branch in shared:
                    b_branch_to_commit[branch] = commit

            # Walk A commits oldest-to-newest, advancing B pointer on shared
            # dest branch matches. Commits without a shared dest branch
            # inherit the pointer from the previous commit (starting at B0).
            b_pointer = b0
            targets = {}
            for commit in a_commits:
                dest = self.db.get_dest_branch(self, commit)
                if dest and dest in shared:
                    b_pointer = b_branch_to_commit[dest]
                targets[commit] = b_pointer

            submodule_targets[sub_path] = targets

        # Rewrite A commits with updated submodule pointers and parent chains
        commit_map = {}

        for commit in a_commits:
            header, body = self.read_commit(commit)

            header_lines = header.splitlines()
            tree_hash = None
            new_header_lines = []
            for line in header_lines:
                if line.startswith("tree "):
                    tree_hash = line.split(" ", 1)[1]
                    new_header_lines.append(line)
                elif line.startswith("parent "):
                    parent = line.split(" ", 1)[1]
                    if parent in commit_map:
                        new_header_lines.append(
                            f"parent {commit_map[parent]}")
                    else:
                        new_header_lines.append(line)
                else:
                    new_header_lines.append(line)

            # Update tree for each submodule
            new_tree = tree_hash
            for sub_path, targets in submodule_targets.items():
                new_tree = self.update_tree_entry(
                    new_tree, sub_path, targets[commit])

            # Rebuild header with updated tree hash
            final_header = "\n".join(
                f"tree {new_tree}" if line.startswith("tree ") else line
                for line in new_header_lines
            )

            new_sha = self.write_commit_object(final_header, body)
            commit_map[commit] = new_sha

        # Update HEAD if anything changed
        last_old = a_commits[-1]
        last_new = commit_map[last_old]
        if last_new != last_old:
            self.update_head(last_new)
            sub_names = ", ".join(sorted(submodule_targets.keys()))
            print(
                f"Aligned {len(submodule_targets)} submodule(s) ({sub_names}) "
                f"across {len(a_commits)} commit(s).")
        else:
            print("Submodules already aligned.", file=sys.stderr)


def usage(c=1):
    print(USAGE)
    sys.exit(c)


def main():
    args = sys.argv[1:]

    if not args or "-h" in args or "--help" in args:
        return usage(0)

    repo = Repo()
    repo.validate()

    cmd, args = args[0], args[1:]

    if cmd == "aim":
        if len(args) > 2: return usage()
        if len(args) == 2:
            return repo.aim(ref=args[0], target=args[1])
        if len(args) == 1:
            if repo.has_ref(args[0]):
                return repo.aim(ref=args[0])
            return repo.aim(target=args[0])
        return repo.aim()

    if cmd == "disarm":
        if len(args) > 1: return usage()
        return repo.disarm(ref=(args[0] if len(args) == 1 else None))

    if cmd == "lob":
        if len(args) > 2: return usage()
        remote = args[0] if len(args) >= 1 else None
        ref = args[1] if len(args) == 2 else None
        return repo.lob(remote=remote, ref=ref)

    if cmd == "id":
        if len(args) > 1: return usage()
        print(repo.change_id(ref=(args[0] if len(args) == 1 else None)))
        return

    if cmd == "lookup":
        if len(args) > 1: return usage()
        target = repo.lookup(ref=(args[0] if len(args) == 1 else None))
        if target: print(target)
        return

    if cmd == "show":
        if len(args) > 2: return usage()
        remote = args[0] if len(args) >= 1 else None
        ref = args[1] if len(args) == 2 else None
        _, _, commits = repo.get_commits(remote=remote, ref=ref)
        for ref in commits:
            print("%s -> %s" % (ref, repo.lookup(ref) or "_"))
        return

    if cmd == "branch":
        remove, rest = "-r" in args, [a for a in args if a != "-r"]
        if remove and len(args) > 3: return usage()
        if not remove and len(args) > 2: return usage()
        remote = rest[0] if len(rest) >= 1 else None
        ref = rest[1] if len(rest) >= 2 else None
        return repo.update_branches(remote=remote, ref=ref, remove=remove)

    if cmd == "align":
        if len(args) > 1: return usage()
        return repo.align(remote=(args[0] if len(args) == 1 else None))

    print(f"Unknown command: {cmd}", file=sys.stderr)
    return usage()


if __name__ == "__main__":
    main()
